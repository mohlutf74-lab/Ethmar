---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

---

<Layout title="Partnerships - Ethmar">
    <Header />
    <!-- Single Page Start -->
        <div class="single mt-125">
            <div class="container">
                <div class="section-header">
                    <p>شراكاتنا</p>
                    <h2>تحالفات استراتيجية تمنحكم عروضاً عقارية خاصة</h2> <br><br>
                    <p>في «إثمار»، نؤمن بأن قوة الاستثمار تُستمد من قوة الشركاء. لذا، عقدنا سلسلة من التحالفات الاستراتيجية مع  مجموعة من كبار المطورين العقاريين في السوق التركي، لنمنح عملاءنا امتيازات حصرية تضمن لهم الأسبقية والأمان.</p>
                </div>
                <div class="row">
                    <div class="col-12">
                        <img src="img/Ethmar1.png" alt="Image">
                        <h3>تحالفاتنا مع كبار المطورين</h3> <br>
                        <p>نفخر بشراكتنا الوثيقة مع كيانات عريقة تمتلك سجلاً حافلاً بالإنجازات العمرانية والمشاريع النوعية (السكنية والتجارية) داخل إسطنبول وخارجها. هذه الشراكات تمنح عملاء «إثمار» ميزات تفضيلية فريدة:</p>
                        <ul class="features-list">
                            <li>
                                <strong>أولوية التخصيص:</strong> 
                                الوصول المبكر لأفضل الوحدات العقارية من حيث الإطلالة والموقع قبل طرحها للعموم.
                            </li>
                            <li>
                                <strong>مرونة السداد:</strong> 
                                الحصول على خطط دفع وتسهيلات ائتمانية حصرية مصممة خصيصاً لعملاء شركتنا.
                            </li>
                            <li>
                                <strong>الموثوقية الإنشائية:</strong> 
                                ضمان التعامل مع مشاريع قائمة على معايير هندسية عالية وتواريخ تسليم دقيقة.
                            </li>
                        </ul>
                        <h4>ومن أبرز شركائنا في النجاح:</h4> <br>
                        <ol style="padding-right: 25px;">
                            <li style="margin-bottom: 15px;">
                                <div>
                                    <strong>شركة هوزاك للإنشاءات (Huzzak):</strong>
                                     رائدة المشاريع السكنية والتجارية الفاخرة، والتي تتميز ببصمتها المعمارية الفريدة في مناطق استراتيجية مثل باشاك شهير، إسكودار، وشيلة.
                                </div>
                            </li>
                            <li>
                                <div>
                                    <strong>شركة باهاش (Bahaş):</strong>
                                     إحدى أعرق الشركات التي تملك تاريخاً طويلاً في تطوير المشاريع الضخمة والبنية التحتية، مما يعزز ثقة المستثمر في جودة الأصول المختارة.
                                </div>
                            </li>
                        </ol>
                        <br><br><br><br>
                        <img src="img/Istanbul.png" alt="Image">
                        <h3>شبكة الوكلاء والوصول المحلي</h3> <br>
                        <p>لا تقتصر شراكاتنا على قطاع الإنشاءات فحسب، بل تمتد لتشمل شبكة واسعة من الاتفاقيات الثنائية مع نخبة من المكاتب العقارية المحلية في مختلف مناطق إسطنبول.</p>
                        <h4>ماذا تعني هذه الشبكة لعملائنا؟</h4> <br>
                        <ul class="features-list">
                            <li>
                                <strong>تغطية جغرافية شاملة:</strong> 
                               تتيح لنا هذه الشراكات الوصول إلى أعمق نقاط السوق العقاري وتوفير فرص استثنائية في كافة مناطق إسطنبول.
                            </li>
                            <li>
                                <strong>فعالية تسييل الاستثمار:</strong> 
                             تساهم هذه الاتفاقيات في توسيع قاعدة المشترين المحتملين، مما يسهل عمليات إعادة البيع للسوق المحلي بفعالية عالية وفي أوقات قياسية، بعيداً عن الطرق التقليدية البطيئة.
                            </li>
                        </ul>
                       
                    </div>
                </div>
            </div>
        </div>
        <!-- Single Page End -->


    

    <Footer />
</Layout>