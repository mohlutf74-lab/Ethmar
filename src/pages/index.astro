---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Carousel from '../components/Carousel.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Ethmar - Home">
    <Header />
	<Carousel />
        

        <!-- About Start -->
        <div class="about">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="about-img">
                            <div class="about-img-1">
                              <img src="img/Logo-blue.png" alt="Image">  
                            </div>
                            <div class="about-img-2">
                                
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="section-header">
                            <p>عن إثمار</p>
                            <h2>من نحن</h2>
                        </div>
                        <div class="about-text">
                            <p>
                                بخبرة ميدانية عميقة في قلب إسطنبول، انطلقت «إثمار» لتمثل جيلاً جديداً من الاستشارات العقارية التي تدمج بين المعرفة المحلية المحدثة والتحليل الاستثماري الدقيق.
                            </p>
                            
                            <a class="btn" href="about.html">للمزيد</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- About End -->


        <!-- Service Start -->
        <div class="service text-right">
            <div class="container style="text-align: right !important; direction: rtl;">
                <div class="section-header">
                    <p></p>
                    <h2>خدماتنا</h2>
                </div>
                <div class="row">
                    
                    <div class="col-lg-3 col-md-6">
                        <div class="service-item">
                            <img src="img/icon-7.png" alt="Icon">
                            <h3>الاستثمار العقاري الحصري</h3>
                            <p>
                                نوفر لك وصولاً مباشراً لأقوى المشاريع الإنشائية قبل طرحها للعلن.
                            </p>
                            
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="service-item">
                            <img src="img/icon-6.png" alt="Icon">
                            <h3>الاستشارات والوساطة</h3>
                            <p>
                                إتمام صفقات البيع والشراء مع الأخذ بعين الاعتبار كل الجوانب القانونية للحفاظ على عملاءنا بشكل كامل.
                            </p>
                            
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="service-item">
                            <img src="img/icon-1.png" alt="Icon">
                            <h3>إدارة الممتلكات</h3>
                            <p>
                                نمنح استثمارك أقصى درجات الاستدامة عبر إدارة تشغيلية متكاملة تشمل التأجير، الالتزام الضريبي، والعناية الفنية .
                            </p>
                            
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="service-item">
                            <img src="img/icon-4.png" alt="Icon">
                            <h3>الجنسية التركية</h3>
                            <p>
                                نوفر لك مجموعة من الفرص العقارية المطابقة لشروط منح الجنسية التركية، ونتولى كافة الإجراءات التنفيذية والقانونية
                            </p>
                            
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 text-center" style="margin-top: 30px;">
                        <a class="btn btn-custom" href="service.html" style="padding: 12px 30px; background: #2b3b4e; color: #fff; border-radius: 5px; text-decoration: none; display: inline-block;">
                            عرض كافة الخدمات
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Service End -->

        
        
        <!-- Contact Start -->
        <div class="contact">
            <div class="container">
                <div class="section-header">
                    <p>مستشارك العقاري في انتظارك</p>
                    <h2>اتصل بنا</h2>
                </div>
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <div class="contact-info">
                            <div class="contact-icon ml-3">
                                <i class="fa fa-map-marker-alt"></i>
                            </div>
                            <div class="contact-text">
                                <h3>العنوان</h3>
                                <p>BARBAROS HAYRETTİN PAŞA MAH. 1995. SOK. AKROS ISTANBUL NO:1 -3 Ofis:463 <br> Istanbul\Türkiye</p>
                            </div>
                        </div>
                        <div class="contact-info">
                            <div class="contact-icon ml-3">
                                <i class="fa fa-phone-alt"></i>
                            </div>
                            <div class="contact-text">
                                <h3>هاتف</h3>
                                <p dir="ltr" style="display: inline-block;">+90 555 029 43 00</p>
                            </div>
                        </div>
                        <div class="contact-info">
                            <div class="contact-icon ml-3">
                                <i class="fa fa-envelope"></i>
                            </div>
                            <div class="contact-text">
                                <h3>البريد الإلكتروني</h3>
                                <p>info@ethmargroupltd.com</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="contact-form">
                            <div id="success"></div>
                            <form name="sentMessage" id="contactForm" novalidate="novalidate">
                                <div class="control-group">
                                    <input type="text" class="form-control" id="name" placeholder="الاسم" required="required" data-validation-required-message="Please enter your name" />
                                    <p class="help-block text-danger"></p>
                                </div>
                                <div class="control-group">
                                    <input type="email" class="form-control" id="email" placeholder="البريد الإلكتروني" required="required" data-validation-required-message="Please enter your email" />
                                    <p class="help-block text-danger"></p>
                                </div>
                                <div class="control-group">
                                    <input type="text" class="form-control" id="subject" placeholder="الموضوع" required="required" data-validation-required-message="Please enter a subject" />
                                    <p class="help-block text-danger"></p>
                                </div>
                                <div class="control-group">
                                    <textarea class="form-control" id="message" placeholder="الطلب" required="required" data-validation-required-message="Please enter your message"></textarea>
                                    <p class="help-block text-danger"></p>
                                </div>
                                <div>
                                    <button class="btn" type="submit" id="sendMessageButton">إرسال</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Contact End -->


        
    

    <Footer />
</Layout>