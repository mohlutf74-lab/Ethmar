---
// src/layouts/Layout.astro
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <title>{title}</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="/img/favicon.ico" rel="icon">
    <link href="https://fonts.googleapis.com/css2?family=Lato&family=Oswald:wght@200;300;400&display=swap" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="/lib/animate/animate.min.css" rel="stylesheet">
    <link href="/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    
<slot />

    <script is:inline src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script is:inline src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/lib/easing/easing.min.js"></script>
    <script is:inline src="/lib/owlcarousel/owl.carousel.min.js"></script>
    <script is:inline src="/lib/waypoints/waypoints.min.js"></script>
    <script is:inline src="/lib/counterup/counterup.min.js"></script>
    <script is:inline src="/mail/jqBootstrapValidation.min.js"></script>
    <script is:inline src="/mail/contact.js"></script>
    <script is:inline src="/js/main.js"></script>
</body>
</html>